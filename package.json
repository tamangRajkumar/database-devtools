{
  "name": "database-devtools-workspace",
  "private": true,
  "scripts": {
    "build": "pnpm --filter database-devtools build && pnpm --filter @database-devtools/sqlite build && pnpm --filter @database-devtools/inspector-sqlite build",
    "dev:cli": "pnpm --filter database-devtools dev",
    "dev:web": "pnpm --filter @database-devtools/web dev",
    "dev:docs": "pnpm --filter @database-devtools/docs dev",
    "dev:example": "pnpm --filter @database-devtools/example start",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter database-devtools test && pnpm --filter @database-devtools/sqlite test && pnpm --filter @database-devtools/inspector-sqlite test",
    "test:ci": "pnpm clean && pnpm build && pnpm test",
    "clean": "pnpm -r exec node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && pnpm publish -r --filter database-devtools --filter @database-devtools/sqlite --filter @database-devtools/inspector-sqlite"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "@changesets/cli": "^2.29.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-native": "0.81.5"
    }
  }
}
