{
  "name": "database-devtools",
  "version": "0.1.9",
  "description": "Inspect SQLite in React Native & Expo from your browser — browse tables, run SQL, edit data. DevTools for mobile databases.",
  "license": "MIT",
  "author": "Rajkumar Tamang",
  "homepage": "https://github.com/tamangRajkumar/database-devtools#readme",
  "bugs": "https://github.com/tamangRajkumar/database-devtools/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamangRajkumar/database-devtools.git",
    "directory": "packages/database-devtools"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/native.js",
  "exports": {
    ".": {
      "react-native": "./dist/native.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./protocol": {
      "types": "./dist/types/protocol.d.ts",
      "import": "./dist/types/protocol.js",
      "default": "./dist/types/protocol.js"
    },
    "./adapter": {
      "react-native": "./dist/adapter/index.js",
      "types": "./dist/adapter/index.d.ts",
      "import": "./dist/adapter/index.js",
      "require": "./dist/adapter/index.cjs",
      "default": "./dist/adapter/index.js"
    },
    "./inspector": {
      "types": "./dist/inspector/index.d.ts",
      "import": "./dist/inspector/index.js",
      "default": "./dist/inspector/index.js"
    },
    "./inspector-sqlite": {
      "types": "./dist/inspectors/sqlite/index.d.ts",
      "import": "./dist/inspectors/sqlite/index.js",
      "default": "./dist/inspectors/sqlite/index.js"
    },
    "./adapters/sqlite": {
      "react-native": "./dist/adapters/sqlite/index.js",
      "types": "./dist/adapters/sqlite/index.d.ts",
      "import": "./dist/adapters/sqlite/index.js",
      "require": "./dist/adapters/sqlite/index.cjs",
      "default": "./dist/adapters/sqlite/index.js"
    }
  },
  "bin": {
    "database-devtools": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:lib": "tsup",
    "build": "pnpm run build:lib && node scripts/build-web.mjs && pnpm run verify:artifacts",
    "prepublishOnly": "node scripts/verify-publish.mjs",
    "verify:artifacts": "node scripts/verify-publish.mjs",
    "dev": "tsx watch src/cli/index.ts",
    "test:metro": "node scripts/verify-metro-fixture.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "expo-sqlite": ">=15",
    "react": ">=18",
    "react-native": ">=0.73",
    "sql.js": ">=1.13"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "sql.js": {
      "optional": true
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "^1.23.0",
    "expo-clipboard": "^7.0.0",
    "expo-constants": "^15.0.0",
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/sql.js": "^1.4.9",
    "@types/ws": "^8.5.13",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-sqlite": "~16.0.10",
    "react": "19.1.0",
    "react-test-renderer": "19.1.0",
    "sql.js": "^1.13.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-sqlite",
    "sqlite",
    "database",
    "devtools",
    "debugging",
    "inspector",
    "database-inspector",
    "mobile-development",
    "sql",
    "react-native-debugging",
    "database-tools",
    "local-database"
  ]
}
