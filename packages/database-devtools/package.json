{
  "name": "database-devtools",
  "version": "0.1.0",
  "description": "Chrome DevTools-like experience for databases in React Native applications",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/native.ts",
  "exports": {
    ".": {
      "react-native": "./src/native.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./protocol": {
      "types": "./dist/types/protocol.d.ts",
      "import": "./dist/types/protocol.js",
      "default": "./dist/types/protocol.js"
    }
  },
  "bin": {
    "database-devtools": "./dist/cli.cjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli/index.ts",
    "prepare": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.73",
    "@expo/vector-icons": ">=14"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    },
    "@expo/vector-icons": {
      "optional": true
    }
  },
  "dependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "~19.1.0",
    "@types/ws": "^8.5.13",
    "react": "19.1.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "react-native",
    "sqlite",
    "database",
    "devtools",
    "debugging"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/database-devtools"
  }
}
