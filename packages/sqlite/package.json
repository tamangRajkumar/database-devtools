{
  "name": "@database-devtools/sqlite",
  "version": "0.1.0",
  "description": "Expo SQLite adapter for Database DevTools",
  "license": "MIT",
  "homepage": "https://github.com/yellowbooking/database-devtools#readme",
  "bugs": "https://github.com/yellowbooking/database-devtools/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yellowbooking/database-devtools.git",
    "directory": "packages/sqlite"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "database-devtools": "workspace:*",
    "expo-sqlite": ">=15"
  },
  "devDependencies": {
    "database-devtools": "workspace:*",
    "expo-sqlite": "~16.0.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
