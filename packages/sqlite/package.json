{
  "name": "@database-devtools/sqlite",
  "version": "0.1.0",
  "description": "Expo SQLite adapter for Database DevTools",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "database-devtools": "workspace:*",
    "expo-sqlite": ">=15"
  },
  "devDependencies": {
    "database-devtools": "workspace:*",
    "expo-sqlite": "~16.0.10",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
