{
  "name": "@database-devtools/inspector-sqlite",
  "version": "0.1.0",
  "description": "SQLite snapshot inspector for Database DevTools browser UI",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "database-devtools": "workspace:*"
  },
  "dependencies": {
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9",
    "database-devtools": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
