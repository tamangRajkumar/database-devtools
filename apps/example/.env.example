# Example app — connect to the DevTools hub
#
# Optional override. When unset, the app auto-detects:
#   - Android emulator → ws://10.0.2.2:3847/ws
#   - Physical device → LAN IP from Metro (expo start)
#   - iOS simulator → ws://localhost:3847/ws

# Android emulator (explicit):
# EXPO_PUBLIC_DATABASE_DEVTOOLS_URL=ws://10.0.2.2:3847/ws

# Physical device on LAN — use your machine's IP (ipconfig / ifconfig):
# EXPO_PUBLIC_DATABASE_DEVTOOLS_URL=ws://192.168.1.10:3847/ws

# Local web + iOS simulator only:
# EXPO_PUBLIC_DATABASE_DEVTOOLS_URL=ws://localhost:3847/ws
